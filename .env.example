# ---------------------------------------------------------------------------
# .env.example — template for local / server credentials. COPY to `.env` and
# fill in. `.env` is gitignored; this template is the ONLY .env* that is tracked
# (.gitignore: `!.env.example`). NEVER put real secrets in THIS file — the
# public-safety hook will reject them, and rightly so.
#
#   cp .env.example .env   &&   edit .env
#
# Used by:
#   - scripts/ibkr_bootstrap.py            (the IBKR socket vars below)
#   - (later) the gnzsnz/ib-gateway-docker service for IBC auto-login
# See documentation/connectivity/connect-providers.md and server-deployment-plan.md.
# ---------------------------------------------------------------------------

# --- IB Gateway / TWS socket (what our code connects TO) -------------------
# Gateway paper default is 127.0.0.1:4002 (live 4001; TWS paper 7497 / live 7496).
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
# Leave blank to let the smoke test draw a reserved "smoke" client id (band 9000),
# which cannot collide with the universe/collector/replay services.
IBKR_CLIENT_ID=
# Optional: the paper account id (starts with DU...). Read-only here.
IBKR_ACCOUNT=

# --- IBC auto-login for the headless gnzsnz/ib-gateway-docker image ---------
# (Not consumed by our Python yet — these drive the Gateway CONTAINER's auto-login
#  once docker-compose lands. PAPER ONLY: never put a live login on the server.)
TWS_USERID=your_paper_username
TWS_PASSWORD=your_paper_password
# paper | live  — keep this `paper`. No funds, nothing to trade live.
TRADING_MODE=paper
# Read-Only API: blocks any order placement even in paper. Keep yes.
READ_ONLY_API=yes
