# ---------------------------------------------------------------------------
# .env.example — template for local / server credentials. COPY to `.env` and
# fill in. `.env` is gitignored; this template is the ONLY .env* that is tracked
# (.gitignore: `!.env.example`). NEVER put real secrets in THIS file — the
# public-safety hook will reject them, and rightly so.
#
#   cp .env.example .env   &&   edit .env
#
# Used by:
#   - packages/infra-ibkr CP REST OAuth    (IBKR_CP_* — the PRODUCTION EOD capture path)
#   - scripts/ibkr_login.py / ibkr_gateway_login.py (IBKR_USERID/IBKR_PASSWORD headless SSO login)
#   - scripts/backup_data_store.py + data-backup.service (ALGOTRADING_BACKUP_ROOT)
#   - scripts/ibkr_bootstrap.py            (the IB Gateway / TWS socket vars — probing only)
# The deployment uses systemd (not docker-compose; compose is dropped — ADR 0055). How the box runs
# the unattended week: scripts/systemd/README.md. CP-REST connectivity: docs/connectivity/.
# ---------------------------------------------------------------------------

# === IBKR Client Portal REST OAuth 1.0a — THE PRODUCTION EOD CAPTURE PATH ===
# This is what the daily EOD close-capture actually uses (packages/infra-ibkr,
# ADR 0024/0031) — NOT the TWS socket block further down. The runner keys
# live-vs-empty on these: with EVERY required var below present and non-blank,
# scripts/eod_run.py binds the live `collect_live` CP REST basket source and
# captures a real chain; with any one missing it falls back to a clean no-capture
# day (exit 0). That is exactly why a bare `uv run python scripts/eod_run.py`
# logs an empty basket today — fill these in.
#
# Obtain the consumer key + access token/secret and register the two RSA keys via
# the IBKR Self-Service OAuth portal (a one-time setup per account). The DH prime
# is the value IBKR publishes for the access-token → live-session-token exchange.
#
# The two PEM vars hold FILE PATHS, never the key bytes (keep the .pem files
# outside the repo, e.g. ~/.secrets/ibkr/, mode 600). The public-safety hook
# rejects real secrets in this tracked template, so leave every value below blank.
IBKR_CP_CONSUMER_KEY=
IBKR_CP_ACCESS_TOKEN=
IBKR_CP_ACCESS_TOKEN_SECRET=
# Absolute paths to the registered RSA private keys (PEM). Not the bytes — the paths.
IBKR_CP_SIGNING_KEY_PEM=
IBKR_CP_ENCRYPTION_KEY_PEM=
# Diffie-Hellman prime (hex) IBKR publishes for the LST exchange.
IBKR_CP_DH_PRIME=
# Optional overrides (DH generator, realm, CP base URL) all have IBKR defaults and
# are omitted here — set IBKR_CP_DH_GENERATOR / IBKR_CP_REALM / IBKR_CP_BASE_URL
# only for a non-standard or test host. See connect-providers.md for the values.

# --- ESCAPE HATCH: local Client Portal Gateway (no Self-Service OAuth) -------
# Set IBKR_CP_GATEWAY=1 to run the SAME EOD capture over the locally-running
# Client Portal Gateway (clientportal.gw) with a browser-login COOKIE session
# instead of the OAuth 1.0a block above — i.e. WITHOUT the IBKR_CP_* artifacts
# and WITHOUT the (flaky) Self-Service OAuth enrolment. Use this when the OAuth
# portal will not enrol (e.g. the "Enable OAuth Access -> 400 not authenticated"
# wall). The trade-off: the Gateway needs a browser re-login ~daily, so this is
# the manual/attended path; the OAuth block above is the unattended one.
#
#   1. Download + run IBKR's clientportal.gw, then open https://localhost:5000
#      and log in (paper is fine) until it shows "Client login succeeds".
#   2. Set the flag below and run `uv run python scripts/eod_run.py`.
# eod_run.py prefers this Gateway path when the flag is set, else the OAuth block,
# else a clean no-capture day. See connect-providers.md.
IBKR_CP_GATEWAY=
# Optional: override the Gateway base URL (default https://localhost:5000/v1/api).
IBKR_CP_GATEWAY_URL=

# === IB Gateway / TWS socket — INTERACTIVE PROBING ONLY =====================
# NOT the production EOD path (that is the IBKR_CP_* OAuth block above). These
# drive scripts/ibkr_bootstrap.py and the interactive probes only — the daily
# capture never touches the socket. Gateway paper default is 127.0.0.1:4002
# (live 4001; TWS paper 7497 / live 7496).
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
# Leave blank to let the smoke test draw a reserved "smoke" client id (band 9000),
# which cannot collide with the universe/collector/replay services.
IBKR_CLIENT_ID=
# Optional: the paper account id (starts with DU...). Read-only here.
IBKR_ACCOUNT=

# --- IBKR login for IB Gateway (desktop) / the headless gnzsnz/ib-gateway image -
# The operator's IBKR username + password. Used for (a) IB Gateway / IBC auto-login
# on the TWS socket, and (b) the SAME login you type into the Client Portal Gateway
# browser session at https://localhost:5000 for the EOD CP-REST capture.
#
# Paper is preferred. A LIVE login is permitted ONLY for read-only market-data
# capture, and ONLY with READ_ONLY_API=yes (which blocks every order). If you set
# TRADING_MODE=live, also set IBKR_PORT=4001 and IBKR_ACCOUNT to the live id (U...).
#
# scripts/ibkr_login.py / ibkr_gateway_login.py PREFER IBKR_USERID / IBKR_PASSWORD and fall back to
# the legacy TWS_USERID / TWS_PASSWORD below. Set whichever pair you keep; the same IBKR account
# login serves the website, the Client Portal Gateway browser session, and IBC auto-login.
IBKR_USERID=your_ibkr_username
IBKR_PASSWORD=your_ibkr_password
TWS_USERID=your_ibkr_username
TWS_PASSWORD=your_ibkr_password
# paper | live  — paper unless you specifically need a live read-only data feed.
TRADING_MODE=paper
# Read-Only API: blocks any order placement (paper AND live). Keep yes.
READ_ONLY_API=yes

# === Canonical store + backup destination ==================================
# ALGOTRADING_DATA_ROOT overrides where the canonical store lives (the EOD runner, the BFF, and
# scripts/eod_healthcheck.py all honour it; default <repo>/data). Leave blank to use the default.
ALGOTRADING_DATA_ROOT=
# ALGOTRADING_BACKUP_ROOT is REQUIRED by data-backup.service — it must point at a SECOND location
# (external disk / NFS / object-store mount), NOT the same disk as the store. A same-disk path
# protects only against a fat-finger, not disk loss; backup_data_store.py refuses to run unset.
ALGOTRADING_BACKUP_ROOT=

# === Frontend assistant — OpenRouter (apps/frontend BFF /api/assistant) =====
# The grounded screen-aware assistant calls OpenRouter (OpenAI-compatible base
# https://openrouter.ai/api/v1) FROM THE BFF — the key NEVER reaches the browser
# and is NEVER committed (leave blank in this tracked template; put the real key
# in your local .env). Absent → /api/assistant returns a labelled 502 and the
# page renders a loud "assistant unavailable" banner; it never fabricates an
# answer. Tests always stub OpenRouter, so CI needs no key.
OPENROUTER_API_KEY=
# Grounded-reasoning model slug (default anthropic/claude-opus-4-8).
ASSISTANT_MODEL=
# Cheaper model for one-line element glosses (default anthropic/claude-haiku-4-5).
ASSISTANT_GLOSS_MODEL=
# Optional OpenRouter attribution headers.
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=
