# Python
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info/
.venv/
.uv-python/

# Coverage (data + reports; the committed branch-coverage floor is in pyproject.toml)
.coverage
.coverage.*
htmlcov/
coverage.xml

# Tool caches (gate tooling: ruff, mypy, pytest, hypothesis, import-linter)
.mypy_cache/
.pytest_cache/
.ruff_cache/
.hypothesis/
.import_linter_cache/

# Node / frontend
node_modules/

# Secrets and local config
.env
.env.*
!.env.example

# Data blobs — keep large/secret data out of git (track READMEs and small fixtures only)
data/**
!data/README.md
!data/**/
*.parquet
*.duckdb
*.db

# Personal scratch — not part of the canonical workspace
ThomasHossen/

# Vincent's AlgoTrading repo (branch refactor/audit-remediation) — reference only,
# source of inspiration for the M-series tasks. Not part of the canonical workspace.
Vincent's Code/

# Lenny's standalone test console — not canonical, imported by nothing. Removed from the repo
# (git rm --cached) but kept on disk for the admin to delete. Not part of the workspace.
Test Lenny/

# Claude Code local (per-user) settings
.claude/settings.local.json

# OS / editor cruft
.DS_Store
*.swp

# Claude Code runtime lock
.claude/scheduled_tasks.lock
