  },
  "openapi": "3.1.0",
  "paths": {
    "/api/analytics": {
      "get": {
        "description": "Return the projected (tenor \u00d7 delta-band) analytics grid for one ticker/day.\n\n``underlying`` defaults to the context default; ``trade_date`` left ``None`` reads across\nevery persisted day for the underlying. A malformed ``trade_date`` yields a labeled 400; an\nunknown ticker or empty grid yields an empty ``maturities`` list with HTTP 200.",
        "operationId": "get_analytics_api_analytics_get",
        "parameters": [
          {
            "in": "query",
            "name": "underlying",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Underlying"
            }
          },
          {
            "in": "query",
            "name": "trade_date",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Trade Date"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Analytics",
        "tags": [
          "analytics"
        ]
      }
    },
    "/api/attribution": {
      "get": {
        "description": "Return one by-Greek attribution record's waterfall payload.\n\n``level`` selects the book aggregate (default) or one position (``position`` + ``contract_key``,\nthe \u00a75.8 drill target). With ``trade_date=None`` the store returns every partition and the\nrecord is selected in Python, so an unknown ``(portfolio, date)`` resolves to a labelled-empty\nbody, not a 500. A malformed ``trade_date`` is a labelled 400.",
        "operationId": "get_attribution_api_attribution_get",
        "parameters": [
          {
            "in": "query",
            "name": "trade_date",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Trade Date"
            }
          },
          {
            "in": "query",
            "name": "portfolio_id",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Portfolio Id"
            }
          },
          {
            "in": "query",
            "name": "level",
            "required": false,
            "schema": {
              "default": "book",
              "title": "Level",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "contract_key",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Contract Key"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Attribution",
        "tags": [
          "attribution"
        ]
      }
    },
    "/api/basket/risk": {
      "post": {
        "description": "Price and risk a composed basket off the stored Tab-1 analytics (read-only).\n\nReads the WS-1F analytics grid for the basket's ``(trade_date, underlying[, provider])`` and\nthe stock-leg spots from ``daily_bar`` on the same date, then sums the per-leg dollar Greeks.\nReturns the priced/risked basket with each dollar number carrying its unit string and the\nper-leg breakdown + labelled gaps (HTTP 200). A malformed basket is a labelled 400.",
        "operationId": "price_basket_api_basket_risk_post",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Price Basket",
        "tags": [
          "basket"
        ]
      }
    },
    "/api/basket/scenarios": {
      "post": {
        "description": "Full-reprice a composed basket over the cartesian (spot x vol) stress grid (WS 2B).\n\nThe interactive, no-cron counterpart to ``GET /api/risk/scenarios`` (which reads the cron's\npersisted surface): reconstructs a valuation per option leg from the stored WS-1F analytics\ngrid (:mod:`..basket_scenarios`), reprices the basket over the config-driven surface, and\nreturns the same surface payload shape the ``StressSurface`` web component renders plus the\nworst-case cell and labelled per-leg gaps. A malformed basket is a labelled 400; an\nunresolved leg is a labelled gap inside a 200, never a 500.",
        "operationId": "stress_basket_api_basket_scenarios_post",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Stress Basket",
        "tags": [
          "basket"
        ]
      }
    },
    "/api/booking/commit": {
      "post": {
        "description": "Commit a previewed ticket into paper fill(s) behind the password gate (read-only, paper).\n\nBuilds the previewed ticket from the body, then runs the write barrier. A malformed request\nis a labelled 400; a gate refusal or an unresolvable leg is a labelled ``block`` (HTTP 200,\nno fill written); a verified, resolvable booking writes the fills + audit record and returns\n``decision: \"commit\"``. **Nothing is transmitted to a broker.**",
        "operationId": "commit_booking_api_booking_commit_post",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Commit Booking",
        "tags": [
          "booking"
        ]
      }
    },
