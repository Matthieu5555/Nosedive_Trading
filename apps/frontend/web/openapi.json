    "/api/constituents": {
      "get": {
        "description": "Return the point-in-time constituent basket for an index, price-first.\n\n``index`` defaults to the context default underlying only as a label fallback; ``as_of``\nmust be supplied for a historical view (it is passed verbatim to the resolver, never\ndefaulted to today for a past date). When ``as_of`` is omitted the basket is resolved as of\ntoday's reconstruction date for a *current* view only.",
        "operationId": "get_constituents_api_constituents_get",
        "parameters": [
          {
            "in": "query",
            "name": "index",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Index"
            }
          },
          {
            "in": "query",
            "name": "as_of",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "As Of"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "422": {
